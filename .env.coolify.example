# ═══════════════════════════════════════════════════════════════════
#  KRIA — Variables de entorno para Coolify
#  Copia este fichero como contenido del bloque "Environment Variables"
#  en Coolify (o pégalas una a una en el formulario).
#
#  IMPORTANTE: cambia todos los valores marcados con <...>
# ═══════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────
# Genera una clave segura en: https://djecrety.ir
DJANGO_SECRET_KEY=<clave-aleatoria-de-50-caracteres>
DJANGO_SETTINGS_MODULE=config.settings.production
# Dominio(s) del servidor separados por coma (sin https://)
DJANGO_ALLOWED_HOSTS=tudominio.es,www.tudominio.es

# ── Base de datos ─────────────────────────────────────────────────
POSTGRES_DB=agamur
POSTGRES_USER=agamur
POSTGRES_PASSWORD=<contraseña-fuerte>

# ── MinIO (almacenamiento de fotos/ficheros) ──────────────────────
MINIO_ACCESS_KEY=<usuario-minio>
MINIO_SECRET_KEY=<contraseña-minio>
MINIO_BUCKET_NAME=agamur
# URL pública desde la que el navegador accede a los ficheros
# Puede ser el mismo dominio con /minio o un subdominio separado
MINIO_EXTERNAL_ENDPOINT=https://tudominio.es

# ── Email (para recuperación de contraseña) ───────────────────────
# Ejemplo con Gmail: EMAIL_HOST=smtp.gmail.com
# Si no tienes SMTP ahora, deja los valores vacíos (el email no funcionará)
EMAIL_HOST=smtp.tuproveedor.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@tudominio.es
EMAIL_HOST_PASSWORD=<contraseña-smtp>
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=KRIA <noreply@tudominio.es>

# ── CORS — orígenes permitidos para el frontend ───────────────────
# Exactamente la URL con la que acceden los usuarios (con https://)
CORS_ALLOWED_ORIGINS=https://tudominio.es,https://www.tudominio.es

# ── URLs de la app ────────────────────────────────────────────────
FRONTEND_URL=https://tudominio.es
# Sufijo de subdominio para resolución multi-tenant
TENANT_DOMAIN_SUFFIX=.tudominio.es

# ── JWT (opcionales, estos son los valores por defecto) ───────────
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7
