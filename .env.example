# ─── Django ───────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────
POSTGRES_DB=kria
POSTGRES_USER=kria
POSTGRES_PASSWORD=kria_dev_password
DATABASE_URL=postgres://kria:kria_dev_password@db:5432/kria

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ─── MinIO ────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=kria
MINIO_USE_HTTPS=false
MINIO_EXTERNAL_ENDPOINT=http://localhost:9000

# ─── Email ────────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@kria.es
EMAIL_HOST_PASSWORD=email-password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=KRIA <noreply@kria.es>

# ─── JWT ──────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── App ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
TENANT_DOMAIN_SUFFIX=.kria.es
