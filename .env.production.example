# ═══════════════════════════════════════════════════════════════════
#  AGAMUR — Production Environment Variables
#  Copy to .env on the VPS and fill in all values before deploying.
# ═══════════════════════════════════════════════════════════════════

# ─── Django ───────────────────────────────────────────────────────
DJANGO_SECRET_KEY=CHANGE_ME_USE_50_RANDOM_CHARS
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ALLOWED_HOSTS=agamur.es,*.agamur.es,TU_IP_DEL_VPS

# ─── Database ─────────────────────────────────────────────────────
POSTGRES_DB=agamur
POSTGRES_USER=agamur
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgres://agamur:CHANGE_ME_STRONG_PASSWORD@db:5432/agamur

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ─── MinIO ────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET_NAME=agamur
MINIO_USE_HTTPS=false
# URL pública accesible desde el navegador
MINIO_EXTERNAL_ENDPOINT=https://files.TU_DOMINIO.es

# ─── Email (SendGrid / Brevo / SMTP propio) ──────────────────────
EMAIL_HOST=smtp.tu-proveedor.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@tu-dominio.es
EMAIL_HOST_PASSWORD=CHANGE_ME_EMAIL_PASSWORD
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=AGAMUR <noreply@tu-dominio.es>

# ─── JWT ──────────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── App ──────────────────────────────────────────────────────────
FRONTEND_URL=https://TU_DOMINIO.es
TENANT_DOMAIN_SUFFIX=.TU_DOMINIO.es

# ─── Dominio SSL ──────────────────────────────────────────────────
# Dominio principal para Let's Encrypt (nginx)
DOMAIN=TU_DOMINIO.es
CERTBOT_EMAIL=tu@email.com
