# Normalise line endings to LF on commit (important for scripts in Linux)
* text=auto eol=lf

# Shell scripts must be LF
*.sh      text eol=lf
*.bash    text eol=lf
Makefile  text eol=lf

# Dockerfiles
Dockerfile*  text eol=lf
*.conf       text eol=lf
*.sql        text eol=lf

# Python / JS / TS
*.py   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.txt  text eol=lf

# Binaries (no conversion)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff2 binary
*.pdf  binary
*.dump binary
